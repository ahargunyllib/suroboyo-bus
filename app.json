{
  "expo": {
    "name": "suroboyo-bus",
    "slug": "suroboyo-bus",
    "version": "1.0.0",
    "scheme": "suroboyo-bus",
    "platforms": ["ios", "android"],
    "plugins": ["expo-router", "expo-font", "expo-asset"],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ahargunyllib.suroboyobus",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "process.env.EXPO_PUBLIC_GOOGLE_API_KEY"
        }
      },
      "package": "com.ahargunyllib.suroboyobus"
    },
    "extra": {
      "eas": {
        "projectId": "346e1743-da93-4829-a631-8e04ce64409d"
      }
    },
    "owner": "ahargunyllib",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/346e1743-da93-4829-a631-8e04ce64409d"
    }
  }
}
